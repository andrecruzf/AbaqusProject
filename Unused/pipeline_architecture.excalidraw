    {"type":"text","id":"s1_var3","x":56,"y":148,"width":1300,"height":22,"text":"BLANK_THICKNESS = 1.0–3.0 mm    ·    MATERIAL_ORIENTATION_ANGLE = 0 · 45 · 90°","originalText":"BLANK_THICKNESS = 1.0–3.0 mm    ·    MATERIAL_ORIENTATION_ANGLE = 0 · 45 · 90°","fontSize":14,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#64748b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":100015,"version":1,"versionNonce":100016,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

    {"type":"text","id":"s0_sub","x":40,"y":-406,"width":900,"height":20,"text":"Both commands share the same pipeline below — difference is in scope and whether FLC aggregation is submitted.","originalText":"Both commands share the same pipeline below — difference is in scope and whether FLC aggregation is submitted.","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#64748b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":1003,"version":1,"versionNonce":1004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},


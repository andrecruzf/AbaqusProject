    {"type":"text","id":"s0_deploy_title","x":55,"y":-364,"width":560,"height":24,"text":"./deploy.sh","originalText":"./deploy.sh","fontSize":18,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#c2410c","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":1007,"version":1,"versionNonce":1008,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"s0_deploy_body","x":55,"y":-330,"width":570,"height":260,"text":"Targeted single simulation\n\nConfig.py defaults — no CLI arguments\nSPECIMEN_WIDTH = single width from config.py\nAll test types: nakazima · marciniak · pip\n\n✗  No FLC aggregation  (exits after copy results)\n\nBest for:\n  PiP tests\n  Individual parameter sweeps\n  Re-running a specific width / geometry","originalText":"Targeted single simulation\n\nConfig.py defaults — no CLI arguments\nSPECIMEN_WIDTH = single width from config.py\nAll test types: nakazima · marciniak · pip\n\n✗  No FLC aggregation  (exits after copy results)\n\nBest for:\n  PiP tests\n  Individual parameter sweeps\n  Re-running a specific width / geometry","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#374151","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":1009,"version":1,"versionNonce":1010,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4},

    {"type":"rectangle","id":"s0_dall_rect","x":700,"y":-378,"width":680,"height":322,"strokeColor":"#b45309","backgroundColor":"#fffbeb","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":1013,"version":1,"versionNonce":1014,"isDeleted":false,"groupIds":[],"boundElements":[],"link":null,"locked":false,"roundness":{"type":3}},
    {"type":"text","id":"s0_dall_title","x":715,"y":-364,"width":650,"height":24,"text":"./deploy_all.sh  [type] [t] [angle] [widths…]","originalText":"./deploy_all.sh  [type] [t] [angle] [widths…]","fontSize":18,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#b45309","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":1015,"version":1,"versionNonce":1016,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"s0_dall_body","x":715,"y":-330,"width":650,"height":260,"text":"Full ISO 12004-2 FLC determination sweep\n\nCLI overrides: type · thickness · angle · widths\nDefault widths: 20 · 50 · 80 · 90 · 100 · 120 · 200\n\n✓  FLC afterok job: nakazima / marciniak + full width set\n✗  PiP or custom widths: FLC job skipped\n\nBest for:\n  nakazima / marciniak FLC sweeps (ISO 12004-2)\n  Batch runs across all specimen widths","originalText":"Full ISO 12004-2 FLC determination sweep\n\nCLI overrides: type · thickness · angle · widths\nDefault widths: 20 · 50 · 80 · 90 · 100 · 120 · 200\n\n✓  FLC afterok job: nakazima / marciniak + full width set\n✗  PiP or custom widths: FLC job skipped\n\nBest for:\n  nakazima / marciniak FLC sweeps (ISO 12004-2)\n  Batch runs across all specimen widths","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#374151","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":1017,"version":1,"versionNonce":1018,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4},

